<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Admin CozyNest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/admin.css")" rel="stylesheet" />
</head>
<body>

    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="admin-brand">
            <div class="admin-avatar"><i class="bi bi-house-heart"></i></div>
            <h6>Admin Portal</h6>
            <p>CozyNest Management</p>
        </div>

        <nav class="admin-nav">
            <a href="@Url.Action("Index", "Admin")"
               class="@(ViewBag.ActivePage == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a href="@Url.Action("Products", "Admin")"
               class="@(ViewBag.ActivePage == "Products" ? "active" : "")">
                <i class="bi bi-box"></i> Products
            </a>
            <a href="@Url.Action("Orders", "Admin")"
               class="@(ViewBag.ActivePage == "Orders" ? "active" : "")">
                <i class="bi bi-bag"></i> Orders
            </a>
            <a href="@Url.Action("Users", "Admin")"
               class="@(ViewBag.ActivePage == "Users" ? "active" : "")">
                <i class="bi bi-people"></i> Users
            </a>
        </nav>

        <div class="admin-bottom">
            <a href="#"><i class="bi bi-gear"></i> Settings</a>
            <a href="@Url.Action("Logout", "Account")"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </div>
    </div>

    <!-- Main -->
    <div class="admin-main">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>