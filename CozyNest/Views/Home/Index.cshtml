@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <link href="@Url.Content("~/Content/home.css")" rel="stylesheet" />
}

<div class="container-fluid px-4">

    <!-- Hero -->
    <div class="hero-section">
        <img src="~/Content/images/hero-section-2.jpg" alt="Hero" />
        <div class="hero-overlay">
            <h1>Make your space feel like home</h1>
            <p>Curated comfort for the intentional dweller. Discover pieces that bring warmth and peace to your environment.</p>
            <a href="@Url.Action("Index", "Product")" class="btn-hero">Shop the Collection</a>
        </div>
    </div>

    <!-- Curated Spaces -->
    <div class="d-flex justify-content-between align-items-center mt-5 mb-3">
        <span class="section-title">Curated Spaces</span>
        <a href="@Url.Action("Index", "Product")" class="section-link">View all categories &rarr;</a>
    </div>
    <div class="category-grid">
        <a href="@Url.Action("Index", "Product", new { category = "Furniture" })" class="category-card large">
            <img src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=1600&q=100" alt="Furniture" />
            <div class="category-card-overlay"></div>
            <div class="category-label">
                Furniture
                <span>Tables, Chairs & More</span>
            </div>
        </a>
        <a href="@Url.Action("Index", "Product", new { category = "Lighting" })" class="category-card">
            <img src="https://images.unsplash.com/photo-1524484485831-a92ffc0de03f?w=1600&q=100" alt="Lighting" />
            <div class="category-card-overlay"></div>
            <div class="category-label">
                Lighting
                <span>Lamps & Fixtures</span>
            </div>
        </a>
        <a href="@Url.Action("Index", "Product", new { category = "Plants" })" class="category-card">
            <img src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=1600&q=100" alt="Plants" />
            <div class="category-card-overlay"></div>
            <div class="category-label">
                Plants & Vases
                <span>Bring Life Indoors</span>
            </div>
        </a>
    </div>

    <!-- Featured Products -->
    <div class="d-flex justify-content-between align-items-center mt-5 mb-4">
        <span class="section-title">Featured Pieces</span>
    </div>
    <div class="row g-3">
        @if (ViewBag.FeaturedProducts != null)
        {
            foreach (var product in ViewBag.FeaturedProducts)
            {
                <div class="col-6 col-md-3">
                    <div class="product-card">
                        <div class="product-card-img">
                            <img src="@product.ImageUrl" alt="@product.Name" />
                            <span class="product-badge">@(product.Stock > 10 ? "In Stock" : "New Arrival")</span>
                        </div>
                        <p class="product-name">@product.Name</p>
                        <p class="product-price">$@product.Price.ToString("0.00")</p>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Placeholder khi chưa có data -->
            for (int i = 0; i < 4; i++)
            {
                <div class="col-6 col-md-3">
                    <div class="product-card">
                        <div class="product-card-img" style="background:#e8e4de;aspect-ratio:1;border-radius:12px;"></div>
                        <p class="product-name">Sample Product</p>
                        <p class="product-price">$0.00</p>
                    </div>
                </div>
            }
        }
    </div>

</div>

<!-- Footer -->
<footer class="site-footer">
    <div class="container-fluid px-4">
        <div class="row">
            <div class="col-md-3 mb-4">
                <p class="footer-brand-name">CozyNest</p>
                <p class="footer-tagline">Intentional living for the modern home. Curated pieces that bring warmth and comfort to your sanctuary.</p>
            </div>
            <div class="col-md-2 offset-md-1 mb-4">
                <p class="footer-heading">Company</p>
                <ul class="footer-links-list">
                    <li><a href="#">Our Story</a></li>
                    <li><a href="#">Sustainability</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a href="@Url.Action("Index", "About")">About Us</a></li>
                </ul>
            </div>
            <div class="col-md-2 mb-4">
                <p class="footer-heading">Shop</p>
                <ul class="footer-links-list">
                    <li><a href="@Url.Action("Index", "Product")">All Products</a></li>
                    <li><a href="@Url.Action("Index", "Product", new { category = "Furniture" })">Furniture</a></li>
                    <li><a href="@Url.Action("Index", "Product", new { category = "Lighting" })">Lighting</a></li>
                    <li><a href="@Url.Action("Index", "Product", new { category = "Textiles" })">Textiles</a></li>
                </ul>
            </div>
            <div class="col-md-2 mb-4">
                <p class="footer-heading">Support</p>
                <ul class="footer-links-list">
                    <li><a href="#">Shipping & Returns</a></li>
                    <li><a href="#">Contact Us</a></li>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Track Order</a></li>
                </ul>
            </div>
            <div class="col-md-2 mb-4">
                <p class="footer-heading">Legal</p>
                <ul class="footer-links-list">
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                    <li><a href="#">Cookie Policy</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom d-flex justify-content-between align-items-center">
            <span>&copy; 2024 CozyNest Decor. Curated for your comfort.</span>
            <div class="d-flex gap-3">
                <a href="#" style="color:var(--cn-text-light);font-size:1.1rem"><i class="bi bi-instagram"></i></a>
                <a href="#" style="color:var(--cn-text-light);font-size:1.1rem"><i class="bi bi-pinterest"></i></a>
                <a href="#" style="color:var(--cn-text-light);font-size:1.1rem"><i class="bi bi-facebook"></i></a>
            </div>
        </div>
    </div>
</footer>>