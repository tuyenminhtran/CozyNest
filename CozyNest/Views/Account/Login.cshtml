@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - CozyNest Decor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/auth.css")" rel="stylesheet" />
</head>
<body>
    <div class="container-fluid h-100">
        <div class="row h-100">

            <!-- Left: Image -->
            <div class="col-md-6 d-none d-md-block p-0 auth-left"
                 style="background-image: url('@Url.Content("~/Content/images/login.jpg")')" 
                 </div>
            <div class="auth-left-overlay">
                <h2>Curated Comfort.</h2>
                <p>Transform your space into a serene sanctuary with<br />our handpicked minimalist decor collection.</p>
            </div>
        </div>

            <!-- Right: Form -->
            <div class="col-md-6 p-0 auth-right">
                <div class="auth-form-box">
                    <h1>CozyNest</h1>
                    <p class="subtitle">Welcome back. Please enter your details to sign in.</p>

                    @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <!-- Email -->
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                @Html.TextBox("Email", null, new { @class = "form-control", placeholder = "Enter your email", type = "email" })
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="mb-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <label class="form-label mb-0">Password</label>
                                <a href="#" class="forgot-link">Forgot Password?</a>
                            </div>
                            <div class="input-group mt-1">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                @Html.Password("Password", null, new { @class = "form-control", placeholder = "Enter your password" })
                            </div>
                        </div>

                        <!-- Error message -->
                        if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger py-2 mt-3" style="font-size:0.85rem">@ViewBag.Error</div>
                        }

                        <!-- Submit -->
                        <button type="submit" class="btn-auth mt-3">Sign In</button>
                    }

                    <p class="auth-switch-text">Don't have an account? <a href="@Url.Action("Register", "Account")">Sign Up</a></p>
                </div>
            </div>

        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>