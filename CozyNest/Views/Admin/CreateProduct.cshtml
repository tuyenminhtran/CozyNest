@{
    ViewBag.Title = "Add Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Products";
}

<div class="mb-4">
    <h1 class="admin-page-title">Add New Product</h1>
    <p class="admin-page-subtitle"><a href="@Url.Action("Products", "Admin")" style="color:#aaa;text-decoration:none">← Back to Products</a></p>
</div>

<div class="admin-form-card">
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger py-2" style="font-size:0.85rem">@ViewBag.Error</div>
    }

    @using (Html.BeginForm("CreateProduct", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Product Name *</label>
            @Html.TextBox("Name", null, new { @class = "form-control", placeholder = "e.g. Nordic Lounge Chair" })
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            @Html.TextArea("Description", null, 3, 0, new { @class = "form-control", placeholder = "Short product description..." })
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Price *</label>
                @Html.TextBox("Price", null, new { @class = "form-control", placeholder = "0.00", type = "number", step = "0.01" })
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Stock</label>
                @Html.TextBox("Stock", null, new { @class = "form-control", placeholder = "0", type = "number" })
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <select name="CategoryId" class="form-select">
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.CategoryId">@cat.Name</option>
                    }
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Image URL</label>
            @Html.TextBox("ImageUrl", null, new { @class = "form-control", placeholder = "https://..." })
        </div>

        <div class="mb-4">
            <label class="form-label">Material</label>
            @Html.TextBox("Material", null, new { @class = "form-control", placeholder = "e.g. Oak Wood, Linen" })
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn-admin-primary">Save Product</button>
            <a href="@Url.Action("Products", "Admin")" class="btn-admin-edit">Cancel</a>
        </div>
    }
</div>
