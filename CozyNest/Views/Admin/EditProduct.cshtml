@model CozyNest.Models.Product
@{
    ViewBag.Title = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActivePage = "Products";
}

<div class="mb-4">
    <h1 class="admin-page-title">Edit Product</h1>
    <p class="admin-page-subtitle"><a href="@Url.Action("Products", "Admin")" style="color:#aaa;text-decoration:none">← Back to Products</a></p>
</div>

<div class="admin-form-card">
    @using (Html.BeginForm("EditProduct", "Admin", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("ProductId", Model.ProductId)

        <div class="mb-3">
            <label class="form-label">Product Name *</label>
            @Html.TextBox("Name", Model.Name, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            @Html.TextArea("Description", Model.Description, 3, 0, new { @class = "form-control" })
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Price *</label>
                @Html.TextBox("Price", Model.Price, new { @class = "form-control", type = "number", step = "0.01" })
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Stock</label>
                @Html.TextBox("Stock", Model.Stock, new { @class = "form-control", type = "number" })
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <select name="CategoryId" class="form-select">
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.CategoryId" @(cat.CategoryId == Model.CategoryId ? "selected" : "")>@cat.Name</option>
                    }
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Image URL</label>
            @Html.TextBox("ImageUrl", Model.ImageUrl, new { @class = "form-control" })
        </div>

        <div class="mb-4">
            <label class="form-label">Material</label>
            @Html.TextBox("Material", Model.Material, new { @class = "form-control" })
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn-admin-primary">Update Product</button>
            <a href="@Url.Action("Products", "Admin")" class="btn-admin-edit">Cancel</a>
        </div>
    }
</div>